# =============================================================================
# OpsPilot — environment variables
# Copy this file to `.env` and fill in real values.
# Never commit the real .env file — it's already in .gitignore.
# =============================================================================

# ---- App ----
ENVIRONMENT=production                 # local | staging | production
SECRET_KEY=changeme-generate-a-long-random-string   # used to sign JWTs, e.g. `openssl rand -hex 32`
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Postgres ----
POSTGRES_USER=opspilot
POSTGRES_PASSWORD=changeme-strong-password
POSTGRES_DB=opspilot
POSTGRES_HOST=postgres                 # service name in docker-compose, "localhost" if running outside Docker
POSTGRES_PORT=5432
# Full SQLAlchemy connection string — keep this in sync with the values above
DATABASE_URL=postgresql+psycopg2://opspilot:changeme-strong-password@postgres:5432/opspilot

# ---- Redis ----
REDIS_PASSWORD=changeme-redis-password
REDIS_URL=redis://:changeme-redis-password@redis:6379/0

# ---- AI providers ----
GROQ_API_KEY=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    # required for /ai/* endpoints (llama3-8b-8192)
OPENAI_API_KEY=                        # optional fallback, only if you switch embeddings/back to OpenAI

# ---- CORS ----
ALLOWED_ORIGINS=http://localhost,https://yourdomain.com

# ---- CI / Deployment ----
RAILWAY_TOKEN=                         # only needed as a GitHub Actions secret for the deploy job